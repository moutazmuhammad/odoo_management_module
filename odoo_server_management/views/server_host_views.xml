<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Host form: type an IP, authorize the key, auto-discover everything -->
    <record id="view_server_host_form" model="ir.ui.view">
        <field name="name">server.host.form</field>
        <field name="model">server.host</field>
        <field name="arch" type="xml">
            <form string="Server Host" js_class="server_mgmt_form">
                <header>
                    <button name="action_test_connection" type="object"
                            string="Test Connection" class="btn-info" icon="fa-plug"
                            groups="odoo_server_management.group_devops"/>
                    <button name="action_discover" type="object"
                            string="Discover Instances" class="btn-primary"
                            icon="fa-search"
                            groups="odoo_server_management.group_operator"
                            attrs="{'invisible': [('op_state', '=', 'running')]}"/>
                    <button name="action_open_terminal" type="object"
                            string="Open Terminal" class="btn-dark" icon="fa-terminal"
                            groups="odoo_server_management.group_devops"/>
                    <button name="action_run_backup_now" type="object"
                            string="Run Backup Now" class="btn-secondary" icon="fa-cloud-upload"
                            groups="odoo_server_management.group_devops"
                            confirm="Build and upload a backup of every database on this server now?"
                            attrs="{'invisible': [('op_state', '=', 'running')]}"/>
                    <button name="action_deploy_agent" type="object"
                            string="Install Self-Backup Agent" class="btn-secondary" icon="fa-download"
                            groups="odoo_server_management.group_operator"
                            confirm="Install a local cron backup agent on this server? It will back itself up daily; the manager will stop backing it up directly."/>
                    <field name="key_authorized" widget="boolean_toggle" readonly="1"
                           string="Connection Verified"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="My Production Server"/></h1>
                    </div>
                    <div class="alert alert-warning" role="alert"
                         attrs="{'invisible': [('backup_review_needed', '=', False)]}">
                        <strong>⚠️ Backup needs review — no recent backup found in the bucket.</strong>
                        <field name="backup_review_reason" readonly="1" nolabel="1"/>
                    </div>
                    <group>
                        <group string="Connection">
                            <field name="ip" placeholder="192.168.1.10" required="1"/>
                            <field name="ssh_port" required="1"
                                   groups="odoo_server_management.group_devops"/>
                        </group>
                        <group string="Status">
                            <field name="instance_count"/>
                            <field name="last_discovery"/>
                            <field name="devops_only" widget="boolean_toggle"
                                   groups="odoo_server_management.group_devops"/>
                            <field name="auto_stop_enabled" groups="odoo_server_management.group_devops"/>
                        </group>
                        <group string="Backups">
                            <field name="backup_category"/>
                            <field name="last_backup"/>
                            <field name="last_backup_check"/>
                            <field name="backup_review_needed" widget="boolean_toggle" readonly="1"/>
                            <field name="backup_agent_enabled" groups="odoo_server_management.group_devops"/>
                            <field name="agent_version" groups="odoo_server_management.group_devops"/>
                            <field name="backup_extra_dbs" groups="odoo_server_management.group_devops"
                                   placeholder="db_one, db_two  (extra DBs for multi-DB / ambiguous stages)"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Notes..."/>
                    <group string="Last Operation" attrs="{'invisible': [('op_state', '=', False)]}">
                        <group>
                            <field name="op_label" readonly="1"/>
                            <field name="op_state" readonly="1"/>
                            <field name="op_time" readonly="1"/>
                        </group>
                        <field name="op_detail" readonly="1" nolabel="1" colspan="2"
                               attrs="{'invisible': [('op_detail', '=', False)]}"
                               placeholder="Discovery output / error…"/>
                    </group>
                    <notebook>
                        <page string="Detected Instances" groups="odoo_server_management.group_devops">
                            <field name="stage_ids">
                                <tree editable="bottom" create="false" delete="false">
                                    <field name="service_name" readonly="1"/>
                                    <field name="odoo_version" readonly="1"/>
                                    <field name="conf_file" readonly="1"/>
                                    <field name="needs_review" readonly="1"/>
                                    <field name="odoo_status" readonly="1"/>
                                    <field name="auto_stop"/>
                                    <button name="action_check_status" type="object"
                                            string="Check Status" icon="fa-refresh"
                                            groups="odoo_server_management.group_user"/>
                                    <button name="action_open_form" type="object"
                                            string="Open / Backups" icon="fa-folder-open-o"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_server_host_tree" model="ir.ui.view">
        <field name="name">server.host.tree</field>
        <field name="model">server.host</field>
        <field name="arch" type="xml">
            <tree string="Server Hosts">
                <field name="name"/>
                <field name="ip"/>
                <field name="backup_category"/>
                <field name="instance_count"/>
                <field name="key_authorized" widget="boolean_toggle" readonly="1"/>
            </tree>
        </field>
    </record>

    <record id="view_server_host_search" model="ir.ui.view">
        <field name="name">server.host.search</field>
        <field name="model">server.host</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="ip"/>
                <field name="backup_category"/>
                <filter name="cat_odex" string="Odex" domain="[('backup_category','=','odex')]"/>
                <filter name="cat_erp" string="ERP" domain="[('backup_category','=','erp')]"/>
                <group expand="1" string="Group By">
                    <filter name="group_category" string="Backup Category"
                            context="{'group_by': 'backup_category'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_server_host" model="ir.actions.act_window">
        <field name="name">Servers</field>
        <field name="res_model">server.host</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_group_category': 1}</field>
    </record>

    <menuitem id="menu_server_hosts" name="Servers"
              parent="menu_server_management"
              action="action_server_host" sequence="15"
              groups="odoo_server_management.group_operator"/>
</odoo>
