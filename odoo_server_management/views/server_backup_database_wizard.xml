<odoo>
  <record id="view_server_backup_database_wizard_form" model="ir.ui.view">
      <field name="name">server.backup.database.wizard.form</field>
      <field name="model">server.backup.database.wizard</field>
      <field name="arch" type="xml">
          <form string="Backup Database">
              <group>
                  <field name="stage_id" invisible="1"/>
                  <field name="db_source" widget="radio" options="{'horizontal': True}"/>
                  <field name="db_pick" options="{'no_create': True, 'no_open': True}"
                         attrs="{'invisible': [('db_source', '!=', 'select')],
                                 'required': [('db_source', '=', 'select')]}"/>
                  <field name="db_name" placeholder="e.g. odex25_rajhi_dev_db"
                         attrs="{'invisible': [('db_source', '!=', 'manual')],
                                 'required': [('db_source', '=', 'manual')]}"/>
                  <field name="backup_format" widget="radio"/>
              </group>
              <footer>
                  <button string="Backup" type="object" name="action_backup" class="btn-primary"/>
                  <button string="Cancel" class="btn-secondary" special="cancel"/>
              </footer>
          </form>
      </field>
  </record>
  
</odoo>
