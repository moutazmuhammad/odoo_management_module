<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="group_category_project_roles" model="ir.module.category">
        <field name="name">Server Management</field>
        <field name="description">Access levels for the Server Management module</field>
    </record>

    <!-- Developer: act on (non-client) instances; see only Branch Configuration
         + Backups + the action buttons. No servers, no settings, no secrets. -->
    <record id="group_user" model="res.groups">
        <field name="name">Developer</field>
        <field name="category_id" ref="group_category_project_roles"/>
    </record>

    <!-- DevOps: everything EXCEPT the General Settings menu — manage Servers
         (create), run Discover Instances, Install Self-Backup Agent, act on
         Client Server stages, all server buttons (Test Connection, Check Status,
         Terminal, Run Backup Now), all stage pages, repository management. -->
    <record id="group_devops" model="res.groups">
        <field name="name">DevOps</field>
        <field name="category_id" ref="group_category_project_roles"/>
        <field name="implied_ids" eval="[(4, ref('group_user'))]"/>
    </record>

    <!-- Administrator: DevOps + the global General Settings. -->
    <record id="group_admin" model="res.groups">
        <field name="name">Administrator</field>
        <field name="category_id" ref="group_category_project_roles"/>
        <field name="implied_ids" eval="[(4, ref('group_devops'))]"/>
    </record>

    <!-- Record rules: a "DevOps Only" server's instances are hidden from plain
         Developers (see rule_stage_developer). Servers themselves are only
         visible to DevOps/Admins, who see all of them. -->
    <record id="rule_host_devops_all" model="ir.rule">
        <field name="name">Servers: DevOps see all</field>
        <field name="model_id" ref="model_server_host"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_devops'))]"/>
    </record>

    <record id="rule_stage_developer" model="ir.rule">
        <field name="name">Stages: hide instances of DevOps-only servers</field>
        <field name="model_id" ref="model_server_stage"/>
        <field name="domain_force">['|', ('host_id', '=', False), ('host_id.devops_only', '=', False)]</field>
        <field name="groups" eval="[(4, ref('group_user'))]"/>
    </record>
    <record id="rule_stage_devops_all" model="ir.rule">
        <field name="name">Stages: DevOps see all</field>
        <field name="model_id" ref="model_server_stage"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_devops'))]"/>
    </record>

</odoo>
