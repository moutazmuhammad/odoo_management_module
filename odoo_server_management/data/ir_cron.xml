<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Background refresh of every instance's database list, on all hosts. -->
    <record id="cron_refresh_databases" model="ir.cron">
        <field name="name">Server Management: Refresh database lists</field>
        <field name="model_id" ref="model_server_host"/>
        <field name="state">code</field>
        <field name="code">model._cron_refresh_databases()</field>
        <field name="interval_number">15</field>
        <field name="interval_type">minutes</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="True"/>
    </record>

    <!-- Auto-refresh each instance's running/stopped status (every 15 min). -->
    <record id="cron_refresh_status" model="ir.cron">
        <field name="name">Server Management: Refresh instance status</field>
        <field name="model_id" ref="model_server_stage"/>
        <field name="state">code</field>
        <field name="code">model._cron_refresh_status()</field>
        <field name="interval_number">15</field>
        <field name="interval_type">minutes</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="True"/>
    </record>

    <!-- Per-project backups: ticks hourly but only acts during the configured
         night hour (Settings → Daily Backup Hour), once per server per day. -->
    <record id="cron_daily_backups" model="ir.cron">
        <field name="name">Server Management: Daily database backups</field>
        <field name="model_id" ref="model_server_host"/>
        <field name="state">code</field>
        <field name="code">model._cron_daily_backups()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="True"/>
        <field name="nextcall" eval="(DateTime.now().replace(minute=0, second=0, microsecond=0) + timedelta(hours=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
    </record>

    <!-- Empty every project's 'manual/' on-demand backups daily at 03:00. -->
    <record id="cron_purge_manual" model="ir.cron">
        <field name="name">Server Management: Purge manual backups (daily 03:00)</field>
        <field name="model_id" ref="model_server_backup_project"/>
        <field name="state">code</field>
        <field name="code">model._cron_purge_manual()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="True"/>
        <field name="nextcall" eval="(DateTime.now().replace(hour=3, minute=0, second=0, microsecond=0) + timedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
    </record>

    <!-- Daily auto-stop of instances running longer than the configured days. -->
    <record id="cron_auto_stop" model="ir.cron">
        <field name="name">Server Management: Auto-stop stale instances</field>
        <field name="model_id" ref="model_server_host"/>
        <field name="state">code</field>
        <field name="code">model._cron_auto_stop()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
